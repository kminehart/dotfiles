{
  "languageserver": {
    "python": {
      "venvFolders": ["envs",".pyenv",".direnv", ".venv"],
      "formatting": {
        "provider": "black"
      }
    },
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"]
    }
  }
}
